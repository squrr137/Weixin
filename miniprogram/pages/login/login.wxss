/* pages/login/login.wxss */
.login-container {
    min-height: 100vh;
    background-color: #F5F7FA;
    padding: 40rpx 30rpx;
    display: flex;
    flex-direction: column;
  }
  
  .login-header {
    text-align: center;
    margin-bottom: 60rpx;
  }
  
  .logo {
    width: 160rpx;
    height: 160rpx;
    margin-bottom: 20rpx;
  }
  
  .app-name {
    display: block;
    font-size: 48rpx;
    font-weight: 600;
    color: #333333;
    margin-bottom: 12rpx;
  }
  
  .app-slogan {
    display: block;
    font-size: 28rpx;
    color: #999999;
  }
  
  .login-form {
    background-color: #FFFFFF;
    border-radius: 24rpx;
    padding: 40rpx 30rpx;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  }
  
  .tab-switch {
    display: flex;
    margin-bottom: 40rpx;
    border-bottom: 2rpx solid #F0F0F0;
  }
  
  .tab-item {
    flex: 1;
    text-align: center;
    padding: 20rpx 0;
    font-size: 32rpx;
    color: #999999;
    position: relative;
  }
  
  .tab-item.active {
    color: #4A90E2;
    font-weight: 500;
  }
  
  .tab-item.active::after {
    content: '';
    position: absolute;
    bottom: -2rpx;
    left: 0;
    right: 0;
    height: 4rpx;
    background-color: #4A90E2;
    border-radius: 2rpx;
  }
  
  .input-group {
    margin-bottom: 30rpx;
  }
  
  .input-label {
    display: block;
    font-size: 28rpx;
    color: #666666;
    margin-bottom: 12rpx;
  }
  
  .input-field {
    background-color: #F5F7FA;
    border-radius: 12rpx;
    padding: 24rpx 30rpx;
    font-size: 30rpx;
    border: 2rpx solid transparent;
    width: 100%;
    box-sizing: border-box;
  }
  
  .input-field:focus {
    border-color: #4A90E2;
    background-color: #FFFFFF;
  }
  
  .code-group {
    margin-bottom: 40rpx;
  }
  
  .code-input-wrapper {
    display: flex;
    align-items: center;
    gap: 20rpx;
  }
  
  .code-input {
    flex: 1;
  }
  
  .code-btn {
    width: 200rpx;
    background-color: #4A90E2;
    color: #FFFFFF;
    font-size: 28rpx;
    padding: 20rpx 0;
    border-radius: 12rpx;
    text-align: center;
    border: none;
  }
  
  .code-btn[disabled] {
    background-color: #CCCCCC;
  }
  
  .btn-primary {
    background-color: #4A90E2;
    color: #FFFFFF;
    border-radius: 40rpx;
    font-size: 32rpx;
    padding: 24rpx 0;
    width: 100%;
    margin: 20rpx 0;
    border: none;
  }
  
  .btn-primary[disabled] {
    background-color: #CCCCCC;
  }
  
  .btn-primary:active {
    background-color: #357ABD;
  }
  
  .btn-secondary {
    background-color: #FFFFFF;
    color: #4A90E2;
    border: 2rpx solid #4A90E2;
    border-radius: 40rpx;
    font-size: 30rpx;
    padding: 20rpx 0;
    width: 100%;
    margin: 20rpx 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .btn-secondary:active {
    background-color: #F0F7FF;
  }
  
  .btn-text {
    background-color: transparent;
    color: #999999;
    font-size: 28rpx;
    border: none;
    margin: 10rpx 0;
    padding: 10rpx 0;
  }
  
  .btn-text::after {
    border: none;
  }
  
  .wx-icon {
    width: 40rpx;
    height: 40rpx;
    margin-right: 12rpx;
  }
  
  .divider {
    display: flex;
    align-items: center;
    margin: 30rpx 0;
  }
  
  .divider::before,
  .divider::after {
    content: '';
    flex: 1;
    height: 2rpx;
    background-color: #F0F0F0;
  }
  
  .divider-text {
    padding: 0 30rpx;
    font-size: 26rpx;
    color: #999999;
  }
  
  .register-link {
    text-align: center;
    margin-top: 40rpx;
    font-size: 28rpx;
    color: #999999;
  }
  
  .link {
    color: #4A90E2;
    margin: 0 8rpx;
  }
  
  .privacy-tip {
    text-align: center;
    margin-top: 40rpx;
    font-size: 24rpx;
    color: #999999;
  }