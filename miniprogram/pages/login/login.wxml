<!-- pages/login/login.wxml -->
<view class="login-container">
  <view class="login-header">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="app-name">精神科合理用药助手</text>
    <text class="app-slogan">您的用药管理智能伙伴</text>
  </view>

  <view class="login-form">
    <!-- 密码登录和验证码登录标签 -->
    <view class="tab-switch">
      <view class="tab-item {{activeTab === 'password' ? 'active' : ''}}" 
            bindtap="switchTab" data-tab="password">密码登录</view>
      <view class="tab-item {{activeTab === 'code' ? 'active' : ''}}" 
            bindtap="switchTab" data-tab="code">验证码登录</view>
    </view>

    <!-- 密码登录 -->
    <block wx:if="{{activeTab === 'password'}}">
      <view class="input-group">
        <text class="input-label">手机号</text>
        <input class="input-field" type="number" placeholder="请输入手机号" 
               bindinput="onPhoneInput" maxlength="11" />
      </view>
      <view class="input-group">
        <text class="input-label">密码</text>
        <input class="input-field" type="password" placeholder="请输入密码" 
               bindinput="onPasswordInput" maxlength="20" />
      </view>
      <button class="btn-primary" bindtap="handlePasswordLogin" 
              loading="{{passwordLoading}}" disabled="{{!canPasswordLogin}}">登录</button>
    </block>

    <!-- 验证码登录 -->
    <block wx:if="{{activeTab === 'code'}}">
      <view class="input-group">
        <text class="input-label">手机号</text>
        <input class="input-field" type="number" placeholder="请输入手机号" 
               bindinput="onPhoneInput" maxlength="11" />
      </view>
      <view class="input-group code-group">
        <text class="input-label">验证码</text>
        <view class="code-input-wrapper">
          <input class="input-field code-input" type="number" placeholder="请输入验证码" 
                 bindinput="onCodeInput" maxlength="6" />
          <button class="code-btn" bindtap="sendVerifyCode" 
                  disabled="{{codeSending || codeCountdown > 0}}">
            {{codeCountdown > 0 ? codeCountdown + 's后重发' : '获取验证码'}}
          </button>
        </view>
      </view>
      <button class="btn-primary" bindtap="handleCodeLogin" 
              loading="{{codeLoading}}" disabled="{{!canCodeLogin}}">登录</button>
    </block>

    <!-- 微信登录区域 -->
    <view class="wx-login">
      <view class="divider">
        <text class="divider-text">其他登录方式</text>
      </view>
      
      <button 
        class="btn-secondary wx-login-btn" 
        bindtap="handleWxLogin"
        loading="{{wxLoginLoading}}"
        disabled="{{wxLoginLoading}}">
        <image class="wx-icon" src="/images/icons/wechat.png" mode="aspectFit"></image>
        微信用户一键登录
      </button>
      
      <button class="btn-text" bindtap="quickLogin">快速体验登录</button>
      <button class="btn-text" bindtap="testBackend">测试后端连接</button>
    </view>

    <!-- 注册链接 -->
    <view class="register-link" wx:if="{{activeTab !== 'wx'}}">
      <text>还没有账号？</text>
      <text class="link" bindtap="goToRegister">立即注册</text>
    </view>
  </view>

  <!-- 隐私协议提示 -->
  <view class="privacy-tip">
    <text>登录即表示您同意</text>
    <text class="link" bindtap="showPrivacy">《用户协议》</text>
    <text>和</text>
    <text class="link" bindtap="showTerms">《隐私政策》</text>
  </view>
</view>