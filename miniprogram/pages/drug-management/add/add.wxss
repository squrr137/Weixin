/* pages/drug-management/add/add.wxss */
.add-container {
    padding: 30rpx;
  }
  
  .card {
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  }
  
  .form-item {
    margin-bottom: 30rpx;
  }
  
  .form-label {
    display: block;
    font-size: 28rpx;
    color: #666666;
    margin-bottom: 12rpx;
  }
  
  .required {
    color: #F44336;
  }
  
  .form-input {
    background-color: #F5F7FA;
    border-radius: 12rpx;
    padding: 20rpx 24rpx;
    font-size: 30rpx;
    border: 2rpx solid transparent;
  }
  
  .form-input:focus {
    border-color: #4A90E2;
    background-color: #FFFFFF;
  }
  
  .form-textarea {
    background-color: #F5F7FA;
    border-radius: 12rpx;
    padding: 20rpx 24rpx;
    font-size: 30rpx;
    width: 100%;
    height: 160rpx;
    border: 2rpx solid transparent;
  }
  
  .form-textarea:focus {
    border-color: #4A90E2;
    background-color: #FFFFFF;
  }
  
  .picker-field {
    background-color: #F5F7FA;
    border-radius: 12rpx;
    padding: 20rpx 24rpx;
    font-size: 30rpx;
    color: #333333;
  }
  
  .schedule-list {
    margin: 20rpx 0;
  }
  
  .schedule-item {
    display: flex;
    align-items: center;
    margin-bottom: 20rpx;
    padding: 20rpx;
    background-color: #F8F9FA;
    border-radius: 12rpx;
  }
  
  .schedule-time {
    flex: 2;
    margin-right: 20rpx;
  }
  
  .time-picker {
    background-color: #FFFFFF;
    padding: 16rpx;
    border-radius: 8rpx;
    text-align: center;
    border: 2rpx solid #EEEEEE;
  }
  
  .schedule-dose {
    flex: 1;
    margin-right: 20rpx;
  }
  
  .dose-input {
    background-color: #FFFFFF;
    padding: 16rpx;
    border-radius: 8rpx;
    border: 2rpx solid #EEEEEE;
    font-size: 28rpx;
    text-align: center;
  }
  
  .schedule-actions {
    flex: 0.5;
    text-align: right;
  }
  
  .action-delete {
    color: #F44336;
    font-size: 26rpx;
    padding: 8rpx;
  }
  
  .repeat-group {
    display: flex;
    gap: 40rpx;
  }
  
  .radio-label {
    display: flex;
    align-items: center;
    font-size: 30rpx;
    margin-right: 30rpx;
  }
  
  .weekday-select {
    margin-top: 20rpx;
    padding-top: 20rpx;
    border-top: 2rpx solid #F0F0F0;
  }
  
  .weekday-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 20rpx;
    margin-top: 16rpx;
  }
  
  .weekday-item {
    width: 120rpx;
    text-align: center;
  }
  
  .form-footer {
    margin-top: 40rpx;
    margin-bottom: 60rpx;
  }
  
  .btn-primary {
    width: 100%;
  }