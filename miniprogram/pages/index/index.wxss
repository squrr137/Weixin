/* pages/index/index.wxss */
.container {
    padding: 0 30rpx;
  }
  
  .header-card {
    background: linear-gradient(135deg, #4A90E2 0%, #7B68EE 100%);
    border-radius: 24rpx;
    padding: 40rpx 30rpx;
    margin: 30rpx 0;
    color: #FFFFFF;
  }
  
  .welcome-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40rpx;
  }
  
  .greeting {
    font-size: 36rpx;
    font-weight: 600;
  }
  
  .date {
    font-size: 28rpx;
    opacity: 0.9;
  }
  
  .stats-grid {
    display: flex;
    justify-content: space-around;
  }
  
  .stat-item {
    text-align: center;
    flex: 1;
  }
  
  .stat-number {
    display: block;
    font-size: 48rpx;
    font-weight: 700;
    margin-bottom: 10rpx;
  }
  
  .stat-label {
    font-size: 26rpx;
    opacity: 0.9;
  }
  
  .quick-actions {
    margin: 40rpx 0;
  }
  
  .action-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20rpx;
    margin-top: 20rpx;
  }
  
  .action-item {
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 24rpx 0;
    text-align: center;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  }
  
  .action-icon {
    width: 48rpx;
    height: 48rpx;
    margin-bottom: 10rpx;
  }
  
  .action-text {
    display: block;
    font-size: 26rpx;
    color: #666666;
  }
  
  .today-medications {
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
    margin: 30rpx 0;
  }
  
  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
  }
  
  .more-link {
    font-size: 26rpx;
    color: #999999;
  }
  
  .medication-list {
    margin-top: 20rpx;
  }
  
  .medication-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx 0;
    border-bottom: 2rpx solid #F5F5F5;
  }
  
  .medication-item:last-child {
    border-bottom: none;
  }
  
  .medication-info {
    flex: 1;
  }
  
  .medication-name {
    display: block;
    font-size: 32rpx;
    font-weight: 500;
    margin-bottom: 8rpx;
  }
  
  .medication-time {
    font-size: 26rpx;
    color: #999999;
  }
  
  .status-btn {
    background-color: #4A90E2;
    color: #FFFFFF;
    font-size: 24rpx;
    padding: 10rpx 24rpx;
    border-radius: 30rpx;
    margin: 0;
  }
  
  .status-btn.pending {
    background-color: #FFA726;
  }
  
  .status-text {
    font-size: 26rpx;
    padding: 8rpx 20rpx;
    border-radius: 30rpx;
  }
  
  .status-text.completed {
    background-color: #E8F5E9;
    color: #4CAF50;
  }
  
  .status-text.delayed {
    background-color: #FFF3E0;
    color: #FF9800;
  }
  
  .status-text.missed {
    background-color: #FFEBEE;
    color: #F44336;
  }
  
  .empty-state {
    text-align: center;
    padding: 60rpx 0;
  }
  
  .empty-icon {
    width: 120rpx;
    height: 120rpx;
    margin-bottom: 20rpx;
    opacity: 0.5;
  }
  
  .empty-text {
    display: block;
    font-size: 28rpx;
    color: #999999;
    margin-bottom: 30rpx;
  }
  
  .recommend-section {
    margin: 40rpx 0;
  }
  
  .recommend-scroll {
    white-space: nowrap;
    margin-top: 20rpx;
  }
  
  .recommend-list {
    display: inline-flex;
  }
  
  .recommend-item {
    display: inline-block;
    width: 260rpx;
    margin-right: 20rpx;
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 20rpx;
  }
  
  .recommend-cover {
    width: 100%;
    height: 160rpx;
    border-radius: 12rpx;
    margin-bottom: 16rpx;
    background-color: #F5F5F5;
  }
  
  .recommend-title {
    display: block;
    font-size: 28rpx;
    font-weight: 500;
    margin-bottom: 8rpx;
    white-space: normal;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  
  .recommend-desc {
    display: block;
    font-size: 24rpx;
    color: #999999;
    white-space: normal;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }