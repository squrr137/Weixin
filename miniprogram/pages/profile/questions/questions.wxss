/* pages/profile/questions/questions.wxss */
.questions-container {
    padding: 30rpx;
    min-height: 100vh;
    background-color: #F5F7FA;
  }
  
  .header-actions {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 30rpx;
  }
  
  .btn-primary {
    width: auto;
    padding: 16rpx 40rpx;
    font-size: 28rpx;
  }
  
  .btn-icon {
    width: 32rpx;
    height: 32rpx;
    margin-right: 8rpx;
    vertical-align: middle;
  }
  
  .faq-section {
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  }
  
  .faq-list {
    margin-top: 20rpx;
  }
  
  .faq-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24rpx 0;
    border-bottom: 2rpx solid #F5F5F5;
  }
  
  .faq-item:last-child {
    border-bottom: none;
  }
  
  .faq-question {
    font-size: 30rpx;
    color: #333333;
    flex: 1;
  }
  
  .questions-list {
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
  }
  
  .list-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30rpx;
  }
  
  .status-filter {
    display: flex;
    align-items: center;
    background-color: #F5F7FA;
    padding: 12rpx 24rpx;
    border-radius: 40rpx;
  }
  
  .status-filter text {
    font-size: 26rpx;
    color: #666666;
    margin-right: 8rpx;
  }
  
  .question-item {
    padding: 24rpx 0;
    border-bottom: 2rpx solid #F5F5F5;
  }
  
  .question-item:last-child {
    border-bottom: none;
  }
  
  .question-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12rpx;
  }
  
  .question-title {
    font-size: 32rpx;
    font-weight: 500;
    color: #333333;
    flex: 1;
    margin-right: 20rpx;
  }
  
  .question-status {
    font-size: 24rpx;
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
  }
  
  .question-status.pending {
    background-color: #FFF3E0;
    color: #FF9800;
  }
  
  .question-status.replied {
    background-color: #E8F5E9;
    color: #4CAF50;
  }
  
  .question-status.closed {
    background-color: #F5F5F5;
    color: #999999;
  }
  
  .question-preview {
    display: block;
    font-size: 28rpx;
    color: #666666;
    margin-bottom: 16rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  
  .question-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .question-time {
    font-size: 24rpx;
    color: #999999;
  }
  
  .reply-count {
    font-size: 24rpx;
    color: #4A90E2;
  }
  
  .modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 1000;
  }
  
  .modal-content {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: #FFFFFF;
    border-radius: 24rpx;
    width: 650rpx;
    max-width: 90%;
    z-index: 1001;
  }
  
  .modal-header {
    padding: 30rpx;
    border-bottom: 2rpx solid #F0F0F0;
    text-align: center;
  }
  
  .modal-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #333333;
  }
  
  .modal-body {
    padding: 30rpx;
  }
  
  .input-group {
    margin-bottom: 30rpx;
  }
  
  .input-label {
    display: block;
    font-size: 28rpx;
    color: #666666;
    margin-bottom: 12rpx;
  }
  
  .form-input {
    background-color: #F5F7FA;
    border-radius: 12rpx;
    padding: 20rpx 24rpx;
    font-size: 30rpx;
    border: 2rpx solid transparent;
  }
  
  .form-input:focus {
    border-color: #4A90E2;
    background-color: #FFFFFF;
  }
  
  .form-textarea {
    background-color: #F5F7FA;
    border-radius: 12rpx;
    padding: 20rpx 24rpx;
    font-size: 30rpx;
    width: 100%;
    height: 200rpx;
    border: 2rpx solid transparent;
  }
  
  .form-textarea:focus {
    border-color: #4A90E2;
    background-color: #FFFFFF;
  }
  
  .modal-footer {
    display: flex;
    gap: 20rpx;
    padding: 30rpx;
    border-top: 2rpx solid #F0F0F0;
  }
  
  .modal-footer button {
    flex: 1;
    margin: 0;
  }
  
  .empty-state {
    text-align: center;
    padding: 60rpx 0;
  }
  
  .empty-icon {
    width: 160rpx;
    height: 160rpx;
    margin-bottom: 30rpx;
    opacity: 0.5;
  }
  
  .empty-text {
    font-size: 28rpx;
    color: #999999;
  }