/* pages/profile/questions/detail/detail.wxss */
.detail-container {
    padding: 30rpx;
    min-height: 100vh;
    background-color: #F5F7FA;
  }
  
  .question-card {
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  }
  
  .question-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20rpx;
  }
  
  .question-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #333333;
    flex: 1;
    margin-right: 20rpx;
  }
  
  .question-status {
    font-size: 24rpx;
    padding: 6rpx 20rpx;
    border-radius: 30rpx;
  }
  
  .question-status.pending {
    background-color: #FFF3E0;
    color: #FF9800;
  }
  
  .question-status.replied {
    background-color: #E8F5E9;
    color: #4CAF50;
  }
  
  .question-status.closed {
    background-color: #F5F5F5;
    color: #999999;
  }
  
  .question-content {
    display: block;
    font-size: 32rpx;
    color: #666666;
    line-height: 1.6;
    margin-bottom: 30rpx;
  }
  
  .question-meta {
    padding-top: 20rpx;
    border-top: 2rpx solid #F5F5F5;
  }
  
  .question-time {
    font-size: 26rpx;
    color: #999999;
  }
  
  .reply-card {
    background-color: #F8F9FA;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
  }
  
  .reply-header {
    display: flex;
    align-items: center;
    margin-bottom: 20rpx;
  }
  
  .reply-avatar {
    width: 64rpx;
    height: 64rpx;
    border-radius: 50%;
    margin-right: 20rpx;
  }
  
  .reply-info {
    flex: 1;
  }
  
  .reply-name {
    display: block;
    font-size: 30rpx;
    font-weight: 500;
    color: #333333;
    margin-bottom: 4rpx;
  }
  
  .reply-time {
    font-size: 24rpx;
    color: #999999;
  }
  
  .reply-content {
    display: block;
    font-size: 30rpx;
    color: #666666;
    line-height: 1.6;
    padding: 20rpx;
    background-color: #FFFFFF;
    border-radius: 12rpx;
  }
  
  .no-reply {
    text-align: center;
    padding: 80rpx 0;
  }
  
  .no-reply-icon {
    width: 160rpx;
    height: 160rpx;
    margin-bottom: 30rpx;
    opacity: 0.5;
  }
  
  .no-reply-text {
    font-size: 28rpx;
    color: #999999;
  }
  
  .action-buttons {
    margin-top: 40rpx;
  }
  
  .btn-secondary {
    width: 100%;
  }