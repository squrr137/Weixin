/* pages/profile/records/learning-records/learning-records.wxss */
.records-container {
    padding: 30rpx;
    min-height: 100vh;
    background-color: #F5F7FA;
  }
  
  .header-card {
    background: linear-gradient(135deg, #4A90E2 0%, #7B68EE 100%);
    border-radius: 24rpx;
    padding: 40rpx 30rpx;
    margin-bottom: 30rpx;
    color: #FFFFFF;
  }
  
  .header-title {
    display: block;
    font-size: 44rpx;
    font-weight: 600;
    margin-bottom: 16rpx;
  }
  
  .header-desc {
    display: block;
    font-size: 28rpx;
    opacity: 0.9;
  }
  
  .stats-summary {
    display: flex;
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  }
  
  .stat-item {
    flex: 1;
    text-align: center;
  }
  
  .stat-value {
    display: block;
    font-size: 48rpx;
    font-weight: 700;
    color: #4A90E2;
    margin-bottom: 8rpx;
  }
  
  .stat-label {
    display: block;
    font-size: 26rpx;
    color: #999999;
  }
  
  .category-stats {
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
  }
  
  .category-item {
    margin-bottom: 24rpx;
  }
  
  .category-item:last-child {
    margin-bottom: 0;
  }
  
  .category-name {
    display: block;
    font-size: 28rpx;
    color: #333333;
    margin-bottom: 12rpx;
  }
  
  .category-progress {
    display: flex;
    align-items: center;
    gap: 20rpx;
  }
  
  .progress-bar {
    flex: 1;
    height: 12rpx;
    background-color: #F0F0F0;
    border-radius: 6rpx;
    overflow: hidden;
  }
  
  .progress-fill {
    height: 100%;
    background-color: #4A90E2;
    border-radius: 6rpx;
  }
  
  .progress-text {
    font-size: 24rpx;
    color: #999999;
    min-width: 80rpx;
    text-align: right;
  }
  
  .records-list {
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
  }
  
  .list-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30rpx;
  }
  
  .time-range {
    display: flex;
    align-items: center;
    background-color: #F5F7FA;
    padding: 12rpx 24rpx;
    border-radius: 40rpx;
  }
  
  .time-range text {
    font-size: 26rpx;
    color: #666666;
    margin-right: 8rpx;
  }
  
  .record-item {
    display: flex;
    align-items: center;
    padding: 24rpx 0;
    border-bottom: 2rpx solid #F5F5F5;
  }
  
  .record-item:last-child {
    border-bottom: none;
  }
  
  .record-icon {
    width: 64rpx;
    height: 64rpx;
    margin-right: 20rpx;
  }
  
  .record-info {
    flex: 1;
  }
  
  .record-title {
    display: block;
    font-size: 30rpx;
    font-weight: 500;
    color: #333333;
    margin-bottom: 8rpx;
  }
  
  .record-meta {
    display: flex;
    align-items: center;
    gap: 20rpx;
  }
  
  .record-category {
    font-size: 24rpx;
    color: #4A90E2;
    background-color: #E8F0FE;
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
  }
  
  .record-time {
    font-size: 24rpx;
    color: #999999;
  }
  
  .record-points {
    font-size: 32rpx;
    font-weight: 600;
    color: #4CAF50;
  }
  
  .empty-state {
    text-align: center;
    padding: 60rpx 0;
  }
  
  .empty-icon {
    width: 160rpx;
    height: 160rpx;
    margin-bottom: 30rpx;
    opacity: 0.5;
  }
  
  .empty-text {
    display: block;
    font-size: 28rpx;
    color: #999999;
    margin-bottom: 30rpx;
  }
  
  .btn-secondary {
    width: 200rpx;
    margin: 0 auto;
  }