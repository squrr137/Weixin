/* pages/profile/records/assessment-records/assessment-records.wxss */
.records-container {
    padding: 30rpx;
    min-height: 100vh;
    background-color: #F5F7FA;
  }
  
  .header-card {
    background: linear-gradient(135deg, #4A90E2 0%, #7B68EE 100%);
    border-radius: 24rpx;
    padding: 40rpx 30rpx;
    margin-bottom: 30rpx;
    color: #FFFFFF;
  }
  
  .header-title {
    display: block;
    font-size: 44rpx;
    font-weight: 600;
    margin-bottom: 16rpx;
  }
  
  .header-desc {
    display: block;
    font-size: 28rpx;
    opacity: 0.9;
  }
  
  .stats-summary {
    display: flex;
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  }
  
  .stat-item {
    flex: 1;
    text-align: center;
  }
  
  .stat-value {
    display: block;
    font-size: 48rpx;
    font-weight: 700;
    color: #4A90E2;
    margin-bottom: 8rpx;
  }
  
  .stat-label {
    display: block;
    font-size: 26rpx;
    color: #999999;
  }
  
  .chart-section {
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
  }
  
  .trend-chart {
    width: 100%;
    height: 300rpx;
    margin-top: 20rpx;
  }
  
  .records-list {
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
  }
  
  .list-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30rpx;
  }
  
  .type-selector {
    display: flex;
    align-items: center;
    background-color: #F5F7FA;
    padding: 12rpx 24rpx;
    border-radius: 40rpx;
  }
  
  .type-selector text {
    font-size: 26rpx;
    color: #666666;
    margin-right: 8rpx;
  }
  
  .record-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx 0;
    border-bottom: 2rpx solid #F5F5F5;
  }
  
  .record-item:last-child {
    border-bottom: none;
  }
  
  .record-info {
    flex: 1;
  }
  
  .record-type {
    display: block;
    font-size: 32rpx;
    font-weight: 500;
    color: #333333;
    margin-bottom: 8rpx;
  }
  
  .record-time {
    font-size: 24rpx;
    color: #999999;
  }
  
  .record-result {
    text-align: right;
  }
  
  .record-score {
    display: block;
    font-size: 40rpx;
    font-weight: 700;
    color: #4A90E2;
    margin-bottom: 4rpx;
  }
  
  .record-level {
    display: inline-block;
    font-size: 24rpx;
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
  }
  
  .record-level.high {
    background-color: #E8F5E9;
    color: #4CAF50;
  }
  
  .record-level.medium {
    background-color: #FFF3E0;
    color: #FF9800;
  }
  
  .record-level.low {
    background-color: #FFEBEE;
    color: #F44336;
  }
  
  .empty-state {
    text-align: center;
    padding: 60rpx 0;
  }
  
  .empty-icon {
    width: 160rpx;
    height: 160rpx;
    margin-bottom: 30rpx;
    opacity: 0.5;
  }
  
  .empty-text {
    display: block;
    font-size: 28rpx;
    color: #999999;
    margin-bottom: 30rpx;
  }
  
  .btn-secondary {
    width: 200rpx;
    margin: 0 auto;
  }