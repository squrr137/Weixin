/* pages/profile/profile.wxss */
.profile-container {
    padding: 30rpx;
  }
  
  .profile-header {
    background: linear-gradient(135deg, #4A90E2 0%, #7B68EE 100%);
    border-radius: 24rpx;
    padding: 40rpx 30rpx;
    margin-bottom: 30rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #FFFFFF;
  }
  
  .avatar-section {
    display: flex;
    align-items: center;
  }
  
  .avatar {
    width: 100rpx;
    height: 100rpx;
    border-radius: 50%;
    margin-right: 20rpx;
    border: 4rpx solid rgba(255, 255, 255, 0.3);
  }
  
  .user-info {
    display: flex;
    flex-direction: column;
  }
  
  .user-name {
    font-size: 36rpx;
    font-weight: 600;
    margin-bottom: 8rpx;
  }
  
  .user-phone {
    font-size: 24rpx;
    opacity: 0.9;
  }
  
  .points-section {
    text-align: center;
    background-color: rgba(255, 255, 255, 0.2);
    padding: 16rpx 30rpx;
    border-radius: 40rpx;
  }
  
  .points-label {
    display: block;
    font-size: 24rpx;
    margin-bottom: 4rpx;
  }
  
  .points-value {
    display: block;
    font-size: 44rpx;
    font-weight: 700;
  }
  
  .stats-grid {
    display: flex;
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx 20rpx;
    margin-bottom: 30rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  }
  
  .stat-item {
    flex: 1;
    text-align: center;
  }
  
  .stat-value {
    display: block;
    font-size: 40rpx;
    font-weight: 700;
    color: #4A90E2;
    margin-bottom: 8rpx;
  }
  
  .stat-label {
    display: block;
    font-size: 24rpx;
    color: #999999;
  }
  
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20rpx;
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx 20rpx;
    margin-bottom: 40rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  }
  
  .menu-item {
    text-align: center;
  }
  
  .menu-icon {
    width: 48rpx;
    height: 48rpx;
    margin-bottom: 12rpx;
  }
  
  .menu-text {
    display: block;
    font-size: 24rpx;
    color: #666666;
  }
  
  .action-buttons {
    margin-top: 40rpx;
  }
  
  .btn-secondary {
    width: 100%;
  }