/** app.wxss **/
page {
    background-color: #F5F7FA;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', sans-serif;
    color: #333333;
  }
  
  /* 容器样式 */
  .container {
    padding: 20rpx 30rpx;
  }
  
  /* 卡片样式 */
  .card {
    background-color: #FFFFFF;
    border-radius: 16rpx;
    padding: 30rpx;
    margin-bottom: 20rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  }
  
  /* 标题样式 */
  .section-title {
    font-size: 36rpx;
    font-weight: 600;
    color: #333333;
    margin-bottom: 20rpx;
    padding-left: 16rpx;
    border-left: 8rpx solid #4A90E2;
  }
  
  .sub-title {
    font-size: 32rpx;
    font-weight: 500;
    color: #666666;
    margin-bottom: 16rpx;
  }
  
  /* 按钮样式 */
  .btn-primary {
    background-color: #4A90E2;
    color: #FFFFFF;
    border-radius: 40rpx;
    font-size: 32rpx;
    padding: 20rpx 0;
    text-align: center;
    margin: 30rpx 0;
  }
  
  .btn-primary:active {
    background-color: #357ABD;
  }
  
  .btn-secondary {
    background-color: #FFFFFF;
    color: #4A90E2;
    border: 2rpx solid #4A90E2;
    border-radius: 40rpx;
    font-size: 32rpx;
    padding: 18rpx 0;
    text-align: center;
    margin: 20rpx 0;
  }
  
  /* 输入框样式 */
  .input-group {
    margin-bottom: 30rpx;
  }
  
  .input-label {
    font-size: 28rpx;
    color: #666666;
    margin-bottom: 10rpx;
    display: block;
  }
  
  .input-field {
    background-color: #F5F7FA;
    border-radius: 12rpx;
    padding: 20rpx 24rpx;
    font-size: 30rpx;
    border: 2rpx solid transparent;
  }
  
  .input-field:focus {
    border-color: #4A90E2;
    background-color: #FFFFFF;
  }
  
  /* 提示文字 */
  .tip-text {
    font-size: 24rpx;
    color: #999999;
    margin-top: 8rpx;
  }
  
  .warning-text {
    font-size: 24rpx;
    color: #E57373;
  }
  
  .success-text {
    font-size: 24rpx;
    color: #4CAF50;
  }
  
  /* 列表样式 */
  .list-item {
    display: flex;
    align-items: center;
    padding: 24rpx 0;
    border-bottom: 2rpx solid #F0F0F0;
  }
  
  .list-item:last-child {
    border-bottom: none;
  }
  
  /* 网格布局 */
  .grid-2 {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20rpx;
  }
  
  .grid-3 {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20rpx;
  }
  
  /* 弹窗样式 */
  .modal-mask {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 1000;
  }
  
  .modal-content {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: #FFFFFF;
    border-radius: 24rpx;
    width: 600rpx;
    max-width: 90%;
    z-index: 1001;
  }